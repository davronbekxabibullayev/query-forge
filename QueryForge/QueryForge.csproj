<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
	
	<PackageId>QueryForge</PackageId>
	<Version>1.0.0</Version>
	
	<Authors> Xabibullayev Davronbek Xabibulla o'g'li</Authors>
	<Company>Xabibullayev Davronbek</Company>
	<Copyright>Copyright © 2026 Xabibullayev Davronbek. All rights reserved.</Copyright>
	<Description>Dynamic LINQ query builder for EF Core</Description>
	<PackageTags>linq;efcore;dynamic;filter;sorting</PackageTags>

	<PackageProjectUrl>https://github.com/davronbekxabibullayev/query-forge</PackageProjectUrl>
	<PackageIcon>icon.png</PackageIcon>
	<RepositoryUrl>https://github.com/davronbekxabibullayev/query-forge.git</RepositoryUrl>
	<RepositoryType>git</RepositoryType>
	<GeneratePackageOnBuild>true</GeneratePackageOnBuild>

	<ItemGroup>
		<PackageReference Include="AutoMapper" Version="16.1.1" />
		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.25" />
	</ItemGroup>

</Project>
